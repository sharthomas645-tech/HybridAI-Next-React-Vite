AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-phi-bucket-name
S3_UPLOAD_PREFIX=phi-uploads/
KMS_KEY_ID=arn:aws:kms:us-west-2:ACCOUNT_ID:key/KEY_ID
