# Next.js App
NEXTAUTH_URL=https://your-domain.com
NODE_ENV=production

# Cognito (Public - used on client side for PKCE redirect)
NEXT_PUBLIC_COGNITO_CLIENT_ID=3qkc2c9ucqhhcc483e1os7qdu4
