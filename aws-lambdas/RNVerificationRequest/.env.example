# RNVerificationRequest — Environment Variables

# AWS region where S3 and KMS resources live
REGION=us-west-2

# S3 bucket for storing RN verification requests
BUCKET_NAME=medlegaldocuments-west2

# Full ARN of the KMS key used for S3 server-side encryption
KMS_KEY_ID=arn:aws:kms:us-west-2:150758096276:key/3d24a626-a55f-41b3-a2f0-c35fb81e6653

# Allowed CORS origin (Azure domain)
ALLOWED_ORIGIN=https://hybridai-next-react-vite-gxf6h5deegewg3bp.westus2-01.azurewebsites.net

# Timeout in milliseconds for AWS SDK requests
REQUEST_TIMEOUT_MS=5000
